# Achords — Environment Configuration
# Copy this file to .env and fill in your values.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   bash scripts/dev-setup.sh

# ── Organization ─────────────────────────────────────────────────────
# GitHub organization name
ORG_NAME=your-org-name

# Work directory (default: ~/achords/{org})
WORK_DIR=~/achords-workspace

# Shared skills repository URL (optional)
# SKILLS_REPO_URL=https://github.com/${ORG_NAME}/.skills.git

# ── gentle-ai Integration ────────────────────────────────────────────
# gentle-ai version to install
GENTLE_VERSION=v1.42.0

# Model for gentle-orchestrator (SDD orchestrator)
OPENCODE_MODEL=opencode/mimo-v2.5-free

# Model for SDD phases (optional, overrides defaults)
# SDD_EXPLORE_MODEL=opencode/big-pickle
# SDD_DESIGN_MODEL=opencode/north-mini-code-free
# SDD_APPLY_MODEL=opencode/north-mini-code-free

# ── Engram (Persistent Memory) ──────────────────────────────────────
# Enable persistent memory across sessions
ENGRAM_ENABLED=true

# Engram project name (auto-detected from .engram/config.json)
# ENGRAM_PROJECT=your-project

# ── GitHub ───────────────────────────────────────────────────────────
# Optional: GitHub token for private repos
# GITHUB_TOKEN=your_token_here

# ── OpenCode ─────────────────────────────────────────────────────────
# OpenCode config directory (default: ~/.config/opencode)
# OPENCODE_CONFIG_DIR=~/.config/opencode
